# Copy to .env and adjust values for your machine
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5068

# Database Configuration
ConnectionStrings__DefaultConnection="Host=localhost;Username=postgres;Database=Inventory_dev;Port=5432;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=500;Connection Idle Lifetime=600;"

# JWT Configuration
Jwt__Secret=replace-with-a-long-random-secret-at-least-32-chars
Jwt__Issuer=InventoryAPI
Jwt__Audience=InventoryAPIUsers

# Optional: set this only when running with HTTPS enabled
# ASPNETCORE_HTTPS_PORT=7171

