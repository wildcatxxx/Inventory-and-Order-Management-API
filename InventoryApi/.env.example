# Copy to .env and adjust values for your machine
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5068

# Database Configuration
ConnectionStrings__DefaultConnection=Server=localhost;Database=InventoryAPI_Dev;User Id=sa;Password=YourStrong!Passw0rd;Encrypt=false;

# JWT Configuration
Jwt__Secret=dev-secret-key-here-minimum-32-characters-for-development
Jwt__Issuer=InventoryAPI
Jwt__Audience=InventoryAPIUsers

# Optional: set this only when running with HTTPS enabled
# ASPNETCORE_HTTPS_PORT=7171

